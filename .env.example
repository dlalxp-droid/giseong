# ============================================
# 카드뉴스 자동화 시스템 환경변수
# ============================================

# --- 콘텐츠 생성 (Claude API) ---
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxx

# --- 브랜딩 ---
BRAND_NAME=@your_brand_name

# --- 인스타그램 (Meta Graph API) ---
META_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxx
IG_USER_ID=17841400000000000

# --- 이미지 호스팅 (Cloudinary) ---
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=000000000000000
CLOUDINARY_API_SECRET=xxxxxxxxxxxxxxxx

# ============================================
# 네이버 밴드
# ============================================

# Open API 사용 시 (mode=api) ─────────────────
# https://developers.band.us → 앱 등록
BAND_CLIENT_ID=xxxxxxxxxxxx
BAND_CLIENT_SECRET=xxxxxxxxxxxxxxxx
BAND_REDIRECT_URI=http://localhost/band_oauth_cb
BAND_ACCESS_TOKEN=ZQAA...
BAND_REFRESH_TOKEN=ZQAA...
# 게시 대상 밴드 키 (scripts/band_auth.py bands 명령으로 조회)
BAND_KEY=AABbbbbb...

# Web 자동 업로드 (mode=web) ──────────────────
# band.us URL https://band.us/band/<BAND_ID>
BAND_ID=12345678
# Playwright storage_state.json 경로 (한 번 로그인하여 쿠키 저장)
BAND_STORAGE_STATE=./band_storage_state.json

# --- 실패 알림 (선택) ---
NOTIFY_WEBHOOK_URL=
